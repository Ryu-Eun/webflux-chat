### 1) A -> B 친구 요청
POST {{baseUrl}}/api/v1/friends/requests/send
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "receiverId": {{userBId}}
}

### 1-1) B가 받은 요청 목록에서 A의 요청 id 찾기
GET {{baseUrl}}/api/v1/friends/requests/received
Authorization: Bearer {{tokenB}}

> {%
    const arr = response.body || [];
    const userAId = Number(client.global.get("userAId"));
    const found = arr.find(x => x.requesterId === userAId);
    if (!found) {
        client.test("A의 요청이 목록에 있어야 함", function(){ client.assert(false, "A->B 요청 못 찾음"); });
    } else {
        client.global.set("reqAB", found.id);
    }
%}

### 1-2) B가 수락
POST {{baseUrl}}/api/v1/friends/requests/{{reqAB}}/accept
Authorization: Bearer {{tokenB}}

### 2) A가 C와 PRIVATE 시도(실패 기대: 친구 아님)
POST {{baseUrl}}/api/v1/chat/rooms/private
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "friendId": {{userCId}}
}

### 3) A-B PRIVATE 생성
POST {{baseUrl}}/api/v1/chat/rooms/private
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "friendId": {{userBId}}
}
> {%
    client.global.set("roomAB1", String(response.body.roomId));
%}

### 3-1) 중복 생성 방지 확인(같은 roomId 기대)
POST {{baseUrl}}/api/v1/chat/rooms/private
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "friendId": {{userBId}}
}
> {%
    const prev = client.global.get("roomAB1");
    const now  = String(response.body.roomId);
    client.test("재사용된 PRIVATE 방이어야 한다", function() {
        client.assert(prev === now, "roomId가 달라요: " + prev + " vs " + now);
    });
%}

### 4) B가 A-B PRIVATE 에서 나가기
POST {{baseUrl}}/api/v1/chat/rooms/{{roomAB1}}/leave
Authorization: Bearer {{tokenB}}

### 4-1) A가 같은 방에 B만 초대 → 새 PRIVATE 생성(NEW_PRIVATE)
POST {{baseUrl}}/api/v1/chat/rooms/{{roomAB1}}/invite
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "userIds": [ {{userBId}} ]
}
> {%
    client.test("NEW_PRIVATE 기대", function() {
        client.assert(response.body.outcome === "NEW_PRIVATE", "outcome = " + response.body.outcome);
    });
    client.global.set("roomAB2", String(response.body.roomId));
%}

### 5) B -> C 친구 요청
POST {{baseUrl}}/api/v1/friends/requests/send
Authorization: Bearer {{tokenB}}
Content-Type: application/json

{
  "receiverId": {{userCId}}
}

### 5-1) C가 받은 요청 목록에서 B의 요청 id 찾기
GET {{baseUrl}}/api/v1/friends/requests/received
Authorization: Bearer {{tokenC}}

> {%
    const arr = response.body || [];
    const userBId = Number(client.global.get("userBId"));
    const found = arr.find(x => x.requesterId === userBId);
    if (!found) {
        client.test("B의 요청이 목록에 있어야 함", function(){ client.assert(false, "B->C 요청 못 찾음"); });
    } else {
        client.global.set("reqBC", found.id);
    }
%}

### 5-2) C가 수락
POST {{baseUrl}}/api/v1/friends/requests/{{reqBC}}/accept
Authorization: Bearer {{tokenC}}

### 5-3) B가 (A-B 최신 PRIVATE) 에 C 초대 → 새 GROUP (NEW_GROUP)
POST {{baseUrl}}/api/v1/chat/rooms/{{roomAB2}}/invite
Authorization: Bearer {{tokenB}}
Content-Type: application/json

{
  "userIds": [ {{userCId}} ]
}
> {%
    client.test("NEW_GROUP 기대", function() {
        client.assert(response.body.outcome === "NEW_GROUP", "outcome = " + response.body.outcome);
    });
    client.global.set("roomABC", String(response.body.roomId));
%}

### 6) A가 B,D,E,F,G,H 로 새 GROUP 생성
POST {{baseUrl}}/api/v1/chat/rooms/group
Authorization: Bearer {{tokenA}}
Content-Type: application/json

{
  "memberIds": [ {{userBId}}, {{userDId}}, {{userEId}}, {{userFId}}, {{userGId}}, {{userHId}} ]
}
> {%
    client.global.set("roomABDEFGH", String(response.body.roomId));
%}

### 7) 6의 그룹에서 B가 C 초대 → 기존 그룹 UPDATED_GROUP
POST {{baseUrl}}/api/v1/chat/rooms/{{roomABDEFGH}}/invite
Authorization: Bearer {{tokenB}}
Content-Type: application/json

{
  "userIds": [ {{userCId}} ]
}
> {%
    client.test("UPDATED_GROUP 기대", function() {
        client.assert(response.body.outcome === "UPDATED_GROUP", "outcome = " + response.body.outcome);
    });
%}

